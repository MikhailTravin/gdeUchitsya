<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Главная</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header.njk' %}
        <main class="main">

            <div class="block-intro">
                <div class="container">
                    <div class="block-intro__content">
                        <div class="block-intro__body">
                            <div class="block-intro__heading-complex">
                                <h1 class="title1">
                                    Где <span>учиться</span>?
                                </h1>
                                <p>
                                    Сотни вузов, колледжей и бизнес-школ на одной площадке.
                                </p>
                            </div>
                            <div class="block-intro-search">
                                <form action="#" class="block-intro-search__body">
                                    <div data-spollers="600,max" class="block-intro-search__inputs">
                                        <div class="block-intro-search__column spollers-item">
                                            <div data-spoller class="block-intro-search__button">
                                                <div class="block-intro-search__titles">
                                                    <svg aria-hidden="true" width="20" height="20">
                                                        <use xlink:href="img/sprite.svg#school"></use>
                                                    </svg>
                                                    <div class="block-intro-search__title">
                                                        Хочу в <span>колледж</span>
                                                    </div>
                                                </div>
                                                <img src="img/icons/arrow1.svg" alt=""
                                                    class="block-intro-search__arrow">
                                            </div>
                                            <div class="block-intro-search__dropdowm">
                                                <div class="options">
                                                    <label class="options__item">
                                                        <input hidden class="options__input" checked type="radio"
                                                            value="1" name="option1">
                                                        <span class="options__label">
                                                            <span class="options__text">в колледж</span>
                                                        </span>
                                                    </label>
                                                    <label class="options__item">
                                                        <input hidden class="options__input" type="radio" value="2"
                                                            name="option1">
                                                        <span class="options__label">
                                                            <span class="options__text">в вуз</span>
                                                        </span>
                                                    </label>
                                                    <label class="options__item">
                                                        <input hidden class="options__input" type="radio" value="3"
                                                            name="option1">
                                                        <span class="options__label">
                                                            <span class="options__text">пройти курс</span>
                                                        </span>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="block-intro-search__column spollers-item">
                                            <div data-spoller class="block-intro-search__button">
                                                <div class="block-intro-search__titles">
                                                    <svg aria-hidden="true" width="20" height="20">
                                                        <use xlink:href="img/sprite.svg#location"></use>
                                                    </svg>
                                                    <div class="block-intro-search__title">
                                                        Город <span>Санкт-Петербург</span>
                                                    </div>
                                                </div>
                                                <img src="img/icons/arrow1.svg" alt=""
                                                    class="block-intro-search__arrow">
                                            </div>
                                            <div class="block-intro-search__dropdowm">
                                                <div class="options">
                                                    <label class="options__item">
                                                        <input hidden class="options__input" checked type="radio"
                                                            value="1" name="option2">
                                                        <span class="options__label">
                                                            <span class="options__text">Санкт-Петербург</span>
                                                        </span>
                                                    </label>
                                                    <label class="options__item">
                                                        <input hidden class="options__input" type="radio" value="2"
                                                            name="option2">
                                                        <span class="options__label">
                                                            <span class="options__text">Москва</span>
                                                        </span>
                                                    </label>
                                                    <label class="options__item">
                                                        <input hidden class="options__input" type="radio" value="3"
                                                            name="option2">
                                                        <span class="options__label">
                                                            <span class="options__text">Казань</span>
                                                        </span>
                                                    </label>
                                                    <label class="options__item">
                                                        <input hidden class="options__input" type="radio" value="4"
                                                            name="option2">
                                                        <span class="options__label">
                                                            <span class="options__text">Красноярск</span>
                                                        </span>
                                                    </label>
                                                    <label class="options__item">
                                                        <input hidden class="options__input" type="radio" value="5"
                                                            name="option2">
                                                        <span class="options__label">
                                                            <span class="options__text">Томск</span>
                                                        </span>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <button type="button" class="btn">Искать</button>
                                </form>
                            </div>
                            <div class="block-intro__cards">
                                <div class="block-intro__card">
                                    <div class="block-intro__number">
                                        1 101
                                    </div>
                                    <div class="block-intro__text">
                                        <svg aria-hidden="true" width="20" height="18">
                                            <use xlink:href="img/sprite.svg#icon1"></use>
                                        </svg>
                                        <span>Вузов</span>
                                    </div>
                                </div>
                                <div class="block-intro__card bg-navy">
                                    <div class="block-intro__number">
                                        2 303
                                    </div>
                                    <div class="block-intro__text">
                                        <svg aria-hidden="true" width="20" height="18">
                                            <use xlink:href="img/sprite.svg#icon2"></use>
                                        </svg>
                                        <span>Колледжей</span>
                                    </div>
                                </div>
                                <div class="block-intro__card bg-purple">
                                    <div class="block-intro__number">
                                        483
                                    </div>
                                    <div class="block-intro__text">
                                        <svg aria-hidden="true" width="17" height="17">
                                            <use xlink:href="img/sprite.svg#icon3"></use>
                                        </svg>
                                        <span>Курсов</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="block-intro__image">
                            <img src="img/image1.webp" alt="">
                        </div>
                    </div>
                </div>
            </div>

        </main>
        {% include 'blocks/footer.njk' %}
    </div>
    {% include 'blocks/popups.njk' %}
    {% include 'blocks/scripts.njk' %}
</body>

</html>